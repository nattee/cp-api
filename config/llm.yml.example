# vLLM / OpenAI-compatible LLM configuration.
# Copy to config/llm.yml and adjust for your environment.
# Used by Line::LlmService for the LINE chatbot's LLM-powered responses.
#
# Each entry under `models:` defines a selectable LLM backend.
# `default_model` is the key used when a user has no preference (llm_model is nil).

default: &default
  default_model: qwen
  # Maximum tool-calling rounds before forcing a text reply
  max_rounds: 5
  # System prompt prepended to every conversation
  system_prompt: |
    You are a helpful assistant for the Department of Computer Engineering, Chulalongkorn University.
    Answer concisely. You may respond in Thai or English depending on the user's language.

    You have these tools:
    - search: Use when the user sends a short or ambiguous message (a name, ID, or number) and you're not sure if they mean a student, lecturer, or course. Searches all entity types at once.
    - student_lookup: Use when you know the user is asking about students. Supports filtering by program, admission year, and status.
    - staff_lookup: Use when you know the user is asking about lecturers/staff. Supports filtering by program, staff type, and status. Supports searching by initials (e.g. "NNN").

    When the user sends just a name or short text without clear context, use the search tool first to identify what they're referring to. Then use the specific tool if more details are needed.
    For "how many" questions, use count_only=true on the specific tool.
    When presenting results, format them clearly and concisely.
  models:
    qwen:
      label: "Qwen 2.5 Coder 32B"
      base_url: "http://localhost:8000"
      endpoint: "/v1/chat/completions"
      model: "qwen2.5-coder-32b"
    glm:
      label: "GLM-4"
      base_url: "http://localhost:8000"
      endpoint: "/v1/chat/completions"
      model: "glm-4"
    kimi:
      label: "Kimi"
      base_url: "http://localhost:8001"
      endpoint: "/v1/chat/completions"
      model: "kimi"

development:
  <<: *default

test:
  <<: *default

production:
  <<: *default
