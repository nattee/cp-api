.card{"data-controller" => "datatable"}
  .card-body.p-3
    .d-flex.justify-content-between.align-items-center.mb-3
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
        = resource_icon
        Imports
      = link_to "New Import", new_data_import_path, class: "btn btn-primary btn-sm"
    .table-responsive
      %table.table.table-hover.mb-0{"data-datatable-target" => "table"}
        %thead
          %tr
            %th Date
            %th Target
            %th Mode
            %th State
            %th Rows
            %th Imported By
            %th Actions
        %tbody
          - @data_imports.each do |di|
            %tr
              %td= di.created_at.strftime("%Y-%m-%d %H:%M")
              %td= di.target_type
              %td
                %span.badge{class: "badge-#{di.mode.dasherize}"}= DataImport::MODE_LABELS[di.mode]
              %td
                %span.badge{class: "badge-#{di.state.dasherize}"}= di.state.titleize
              %td
                - if di.state == "completed"
                  = di.created_count + di.updated_count
                  %span.text-muted / #{di.total_rows}
                - elsif di.state == "failed" && di.error_count > 0
                  %span.text-danger= "#{di.error_count} errors"
                  %span.text-muted / #{di.total_rows}
                - else
                  = di.total_rows
              %td= di.user.name
              %td
                - if di.state.in?(%w[pending retrying])
                  = link_to mapping_data_import_path(di), class: "btn-ghost btn-ghost-primary", title: "Configure" do
                    %span.material-symbols{style: "font-size: 18px"} tune
                - else
                  = link_to data_import_path(di), class: "btn-ghost btn-ghost-primary", title: "Show" do
                    %span.material-symbols{style: "font-size: 18px"} visibility
                  - if di.state.in?(%w[failed completed])
                    = button_to retry_import_data_import_path(di), method: :patch, class: "btn-ghost btn-ghost-secondary", title: "Retry", form: { class: "d-inline" } do
                      %span.material-symbols{style: "font-size: 18px"} refresh
