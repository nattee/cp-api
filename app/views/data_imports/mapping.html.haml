.d-flex.justify-content-between.align-items-center.mb-3
  %h1 Configure Import
  = link_to "Cancel", data_imports_path, class: "btn btn-outline-primary"

-# Summary card
.card.mb-3
  .card-body
    %dl.dl-fields.dl-value-emphasis.row.mb-0
      %dt.col-sm-3 Target
      %dd.col-sm-9
        = resource_icon(@data_import.target_type.tableize)
        = @data_import.target_type

      %dt.col-sm-3 Mode
      %dd.col-sm-9
        %span.badge{class: "badge-#{@data_import.mode.dasherize}"}= DataImport::MODE_LABELS[@data_import.mode]

      %dt.col-sm-3 File
      %dd.col-sm-9= @data_import.file.filename

-# Sheet selector and skip_failures side by side
- show_sheet = @show_sheet_selector
- show_skip = @data_import.state == "retrying"
- if show_sheet || show_skip
  .row.mb-3
    - if show_sheet
      .col-md-6.mb-3.mb-md-0
        .card.h-100
          .card-body
            %h6.section-title Sheet
            = form_tag mapping_data_import_path(@data_import), method: :get do
              = select_tag :sheet, options_for_select(@sheets, @selected_sheet), class: "form-select", onchange: "this.form.requestSubmit()"
    - if show_skip
      .col-md-6.mb-3.mb-md-0
        .card.h-100
          .card-body
            %h6.section-title Error Handling
            .form-text.text-muted.mb-2
              By default, the import is
              %strong all-or-nothing:
              if any row fails, the entire import is rolled back and no records are saved.
            .form-check.form-switch
              = check_box_tag :skip_failures, "1", false, class: "form-check-input", id: "skip_failures", form: "import-form"
              = label_tag :skip_failures, "Skip failed rows", class: "form-check-label"
              .form-text.text-muted
                Save successful records and skip rows with errors.

-# Column mapping
= form_tag execute_data_import_path(@data_import), method: :patch, id: "import-form" do
  = hidden_field_tag :sheet_name, @selected_sheet

  .card.mb-3{"data-controller" => "mapping-preview", "data-mapping-preview-headers-value" => @file_headers.to_json, "data-mapping-preview-row-value" => @preview_row.map { |v| v&.to_s }.to_json}
    .card-body.p-3
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center.mb-3
        %span.material-symbols.resource-icon.me-2 table_chart
        Column Mapping
      %table.table.table-hover.mb-0
        %thead
          %tr
            %th Field
            %th Source
            %th Preview
        %tbody
          - @attribute_definitions.each do |defn|
            - attr = defn[:attribute]
            - auto_mapped_header = @auto_mapping[attr]
            - preview_idx = auto_mapped_header ? @file_headers.index(auto_mapped_header) : nil
            - source_options = [["-- skip --", ""], ["-- fixed value --", "__constant__"]] + @file_headers.map { |h| [h, h] }
            %tr
              %td
                = defn[:label]
                - if defn[:required]
                  %span.text-danger *
                - if defn[:help].present?
                  %button.help-popover-trigger{type: "button", tabindex: "0"}
                    %span.material-symbols{style: "font-size: 16px"} help
                    %span.help-popover-content= defn[:help]
              %td
                = select_tag "mapping[#{attr}]", options_for_select(source_options, auto_mapped_header), class: "form-select form-select-sm mapping-source-select", "data-controller" => "select2", "data-select2-allow-clear" => "", "data-select2-dropdown-class" => "select2-dropdown--monospace", "data-mapping-attr" => attr
              %td.preview-cell{"data-mapping-preview" => attr}
                %span.text-muted{"data-mapping-preview-text" => attr}
                  - if preview_idx
                    = @preview_row[preview_idx]
                  - else
                    \--
                - if defn[:fixed_options]
                  = select_tag "defaults[#{attr}]", options_for_select([["Select...", ""]] + defn[:fixed_options].call), class: "form-select form-select-sm", hidden: true, "data-mapping-constant" => attr
                - else
                  = text_field_tag "defaults[#{attr}]", nil, class: "form-control form-control-sm", placeholder: "Enter value...", hidden: true, "data-mapping-constant" => attr

  - if @data_import.target_type == "Grade"
    .card.mb-3
      .card-body.p-3
        %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center.mb-3
          %span.material-symbols.resource-icon.me-2 tune
          Import Options
        .row
          .col-md-6
            %label.form-label When grade is blank
            = select_tag "defaults[_blank_grade]", options_for_select([["Skip row — do not import", "skip"], ["Import without grade", "import"]], "skip"), class: "form-select form-select-sm"
            .form-text.text-muted
              Rows where the grade column is empty or missing.

  .d-flex.justify-content-end
    = submit_tag "Run Import", class: "btn btn-primary"
