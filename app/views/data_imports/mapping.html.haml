.d-flex.justify-content-between.align-items-center.mb-3
  %h1 Configure Import
  = link_to "Cancel", data_imports_path, class: "btn btn-outline-primary"

-# Summary card
.card.mb-3
  .card-body
    %dl.dl-fields.dl-value-emphasis.row.mb-0
      %dt.col-sm-3 Target
      %dd.col-sm-9
        = resource_icon(@data_import.target_type.tableize)
        = @data_import.target_type

      %dt.col-sm-3 Mode
      %dd.col-sm-9
        %span.badge{class: "badge-#{@data_import.mode.dasherize}"}= DataImport::MODE_LABELS[@data_import.mode]

      %dt.col-sm-3 File
      %dd.col-sm-9= @data_import.file.filename

-# Already-configured sheets
- if @configured_sheets.any?
  .card.mb-3
    .card-body.p-3
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center.mb-3
        %span.material-symbols.resource-icon.me-2 playlist_add_check
        Configured Sheets
      - labels = @data_import.importer_class.attribute_labels
      %table.table.table-sm.mb-0
        %thead
          %tr
            %th Sheet
            %th Mapped Fields
            %th{style: "width: 1%"}
        %tbody
          - @configured_sheets.each do |config|
            %tr
              %td= config["sheet_name"]
              %td
                - mapped = (config["column_mapping"] || {}).keys + (config["default_values"] || {}).reject { |k, _| k.start_with?("_") }.keys
                = mapped.map { |a| labels[a.to_sym] || a }.join(", ")
              %td.text-nowrap
                = link_to mapping_data_import_path(@data_import, sheet: config["sheet_name"]), class: "btn-ghost btn-ghost-secondary", title: "Edit" do
                  %span.material-symbols{style: "font-size: 18px"} edit
                = button_to remove_sheet_data_import_path(@data_import, sheet_name: config["sheet_name"]), method: :delete, class: "btn-ghost btn-ghost-danger", title: "Remove", form: { class: "d-inline" } do
                  %span.material-symbols{style: "font-size: 18px"} close
      .d-flex.justify-content-end.mt-3
        = form_tag execute_data_import_path(@data_import), method: :patch, class: "d-inline" do
          = submit_tag "Run Import", class: "btn btn-primary"

-# Sheet selector and skip_failures side by side
- show_sheet = @show_sheet_selector
- show_skip = @data_import.state == "retrying"
- if show_sheet || show_skip
  .row.mb-3
    - if show_sheet
      .col-md-6.mb-3.mb-md-0
        .card.h-100
          .card-body
            %h6.section-title Sheet
            = form_tag mapping_data_import_path(@data_import), method: :get do
              = select_tag :sheet, options_for_select(@sheets, @selected_sheet), class: "form-select", onchange: "this.form.requestSubmit()"
    - if show_skip
      .col-md-6.mb-3.mb-md-0
        .card.h-100
          .card-body
            %h6.section-title Error Handling
            .form-text.text-muted.mb-2
              By default, the import is
              %strong all-or-nothing:
              if any row fails, the entire import is rolled back and no records are saved.
            .form-check.form-switch
              = check_box_tag :skip_failures, "1", false, class: "form-check-input", id: "skip_failures", form: "import-form"
              = label_tag :skip_failures, "Skip failed rows", class: "form-check-label"
              .form-text.text-muted
                Save successful records and skip rows with errors.

-# Column mapping
= form_tag execute_data_import_path(@data_import), method: :patch, id: "import-form" do
  = hidden_field_tag :sheet_name, @selected_sheet

  .card.mb-3{"data-controller" => "mapping-preview", "data-mapping-preview-headers-value" => @file_headers.to_json, "data-mapping-preview-row-value" => @preview_row.map { |v| v&.to_s }.to_json}
    .card-body.p-3
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center.mb-3
        %span.material-symbols.resource-icon.me-2 table_chart
        Column Mapping
        - if @selected_sheet
          %span.text-muted.ms-2.fw-normal= "— #{@selected_sheet}"
      %table.table.table-hover.mb-0
        %thead
          %tr
            %th Field
            %th Source
            %th Preview
        %tbody
          - @attribute_definitions.each do |defn|
            - attr = defn[:attribute]
            - use_default_fixed = false
            - use_group = false
            - if @editing_sheet
              - saved_col = @saved_mapping[attr.to_s]
              - saved_default = @saved_defaults[attr.to_s]
              - saved_group = @saved_defaults["_program_group_id"] if defn[:group_options]
              - if saved_col
                - selected_source = saved_col
                - preview_idx = @file_headers.index(saved_col)
                - default_val = nil
              - elsif saved_group && defn[:group_options]
                - selected_source = "__program_group__"
                - preview_idx = nil
                - use_group = true
                - default_val = nil
                - group_val = saved_group
              - elsif saved_default
                - selected_source = "__constant__"
                - preview_idx = nil
                - use_default_fixed = true
                - default_val = saved_default
              - else
                - selected_source = nil
                - preview_idx = nil
                - default_val = nil
            - else
              - auto_mapped_header = @auto_mapping[attr]
              - use_default_fixed = !auto_mapped_header && defn[:default_fixed_value].present?
              - selected_source = auto_mapped_header || (use_default_fixed ? "__constant__" : nil)
              - preview_idx = auto_mapped_header ? @file_headers.index(auto_mapped_header) : nil
              - default_val = use_default_fixed ? defn[:default_fixed_value] : nil
            - source_options = [["-- skip --", ""], ["-- fixed value --", "__constant__"]]
            - if defn[:group_options]
              - source_options << ["-- from program group --", "__program_group__"]
            - source_options += @file_headers.map { |h| [h, h] }
            %tr
              %td
                = defn[:label]
                - if defn[:required]
                  - if @derivable_attributes&.include?(defn[:attribute])
                    %span.text-muted *
                  - else
                    %span.text-danger *
                - if defn[:help].present?
                  %button.help-popover-trigger{type: "button", tabindex: "0"}
                    %span.material-symbols{style: "font-size: 16px"} help
                    %span.help-popover-content= defn[:help]
              %td
                = select_tag "mapping[#{attr}]", options_for_select(source_options, selected_source), class: "form-select form-select-sm mapping-source-select", "data-controller" => "select2", "data-select2-allow-clear" => "", "data-select2-dropdown-class" => "select2-dropdown--monospace", "data-mapping-attr" => attr
              %td.preview-cell{"data-mapping-preview" => attr}
                %span.text-muted{"data-mapping-preview-text" => attr, hidden: use_default_fixed || nil}
                  - if preview_idx
                    = @preview_row[preview_idx]
                  - else
                    \--
                - if defn[:fixed_options]
                  = select_tag "defaults[#{attr}]", options_for_select([["Select...", ""]] + defn[:fixed_options].call, default_val), class: "form-select form-select-sm", hidden: !use_default_fixed || nil, "data-mapping-constant" => attr
                - else
                  = text_field_tag "defaults[#{attr}]", default_val, class: "form-control form-control-sm", placeholder: "Enter value...", hidden: !use_default_fixed || nil, "data-mapping-constant" => attr
                - if defn[:group_options]
                  %span{"data-mapping-group" => attr, hidden: !use_group || nil}
                    = select_tag "defaults[_program_group_id]", options_for_select([["Select group...", ""]] + defn[:group_options].call, use_group ? group_val : nil), class: "form-select form-select-sm", "data-controller" => "select2"

  - if @data_import.target_type == "Grade"
    .card.mb-3
      .card-body.p-3
        %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center.mb-3
          %span.material-symbols.resource-icon.me-2 tune
          Import Options
        .row
          .col-md-6
            %label.form-label When grade is blank
            - blank_grade_val = @editing_sheet ? (@saved_defaults["_blank_grade"] || "skip") : "skip"
            = select_tag "defaults[_blank_grade]", options_for_select([["Skip row — do not import", "skip"], ["Import without grade", "import"]], blank_grade_val), class: "form-select form-select-sm"
            .form-text.text-muted
              Rows where the grade column is empty or missing.

  .d-flex.justify-content-end.gap-2
    - if @show_sheet_selector
      - if @editing_sheet
        = button_tag class: "btn btn-outline-primary", type: "submit", formaction: save_sheet_data_import_path(@data_import) do
          %span.material-symbols.me-1{style: "font-size: 18px; vertical-align: middle"} save
          Save Sheet
      - elsif @available_sheets.size > 1
        = button_tag class: "btn btn-outline-primary", type: "submit", formaction: save_sheet_data_import_path(@data_import) do
          %span.material-symbols.me-1{style: "font-size: 18px; vertical-align: middle"} add
          Save & Add Next Sheet
    = submit_tag "Save & Run Import", class: "btn btn-primary"
