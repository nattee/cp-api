= form_with(model: user, class: "needs-validation") do |f|
  - if user.errors.any?
    .alert.alert-danger
      %h5.alert-heading
        = pluralize(user.errors.count, "error")
        prohibited this user from being saved:
      %ul.mb-0
        - user.errors.full_messages.each do |message|
          %li= message

  .mb-3
    = f.label :username, class: "form-label"
    .input-group
      %span.input-group-text
        %span.material-symbols person
      = f.text_field :username, class: "form-control #{'is-invalid' if user.errors[:username].any?}"
      - if user.errors[:username].any?
        .invalid-feedback= user.errors[:username].first

  .mb-3
    = f.label :email, class: "form-label"
    .input-group
      %span.input-group-text
        %span.material-symbols mail
      = f.email_field :email, class: "form-control #{'is-invalid' if user.errors[:email].any?}"
      - if user.errors[:email].any?
        .invalid-feedback= user.errors[:email].first

  .mb-3
    = f.label :name, class: "form-label"
    .input-group
      %span.input-group-text
        %span.material-symbols badge
      = f.text_field :name, class: "form-control #{'is-invalid' if user.errors[:name].any?}"
      - if user.errors[:name].any?
        .invalid-feedback= user.errors[:name].first

  .mb-3
    = f.label :password, class: "form-label"
    .input-group
      %span.input-group-text
        %span.material-symbols lock
      = f.password_field :password, class: "form-control #{'is-invalid' if user.errors[:password].any?}"
      - if user.errors[:password].any?
        .invalid-feedback= user.errors[:password].first
    - if user.persisted?
      .form-text Leave blank to keep current password.

  .mb-3
    = f.label :password_confirmation, class: "form-label"
    .input-group
      %span.input-group-text
        %span.material-symbols lock
      = f.password_field :password_confirmation, class: "form-control #{'is-invalid' if user.errors[:password_confirmation].any?}"
      - if user.errors[:password_confirmation].any?
        .invalid-feedback= user.errors[:password_confirmation].first

  .mb-3
    = f.label :role, class: "form-label"
    = f.select :role, options_for_select(User::ROLES.map { |r| [r.titleize, r, { data: { icon: User::ROLE_ICONS[r] } }] }, user.role), {}, class: "form-select #{'is-invalid' if user.errors[:role].any?}", data: { controller: "select2" }
    - if user.errors[:role].any?
      .invalid-feedback= user.errors[:role].first

  .mb-3.form-check
    = f.check_box :active, class: "form-check-input"
    = f.label :active, class: "form-check-label"

  %fieldset.mb-3
    %legend.fs-6.text-muted SSO (optional)
    .row
      .col-md-6.mb-3
        = f.label :provider, class: "form-label"
        .input-group
          %span.input-group-text
            %span.material-symbols key
          = f.text_field :provider, class: "form-control"
      .col-md-6.mb-3
        = f.label :uid, "UID", class: "form-label"
        .input-group
          %span.input-group-text
            %span.material-symbols fingerprint
          = f.text_field :uid, class: "form-control"

  %fieldset.mb-3
    %legend.fs-6.text-muted LINE Chatbot
    .mb-3.form-check
      = f.check_box :llm_consent, class: "form-check-input"
      = f.label :llm_consent, "LLM Consent", class: "form-check-label"
      .form-text Allow sending this user's LINE messages to the LLM backend.
    .mb-3
      = f.label :llm_model, "LLM Model", class: "form-label"
      = f.select :llm_model, options_for_select([["Default", ""]] + LLM_CONFIG[:models].map { |k, v| [v[:label], k.to_s] }, user.llm_model), {}, class: "form-select"
      .form-text Preferred LLM model. "Default" uses the system default.
    .mb-3.form-check
      = f.check_box :debug_tool_calls, class: "form-check-input"
      = f.label :debug_tool_calls, "Debug Tool Calls", class: "form-check-label"
      .form-text Show full LLM tool chain details in chat history.

  = f.submit class: "btn btn-primary"
