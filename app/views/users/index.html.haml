.d-flex.justify-content-between.align-items-center.mb-3
  %h1 Users
  = link_to "New User", new_user_path, class: "btn btn-primary"

.card
  .card-body
    .table-responsive
      %table.table.table-hover.mb-0
        %thead
          %tr
            %th Username
            %th Email
            %th Name
            %th Role
            %th Active
            %th Actions
        %tbody
          - @users.each do |user|
            %tr
              %td= user.username
              %td= user.email
              %td= user.name
              %td
                %span.badge{class: user.admin? ? "badge-admin" : user.staff? ? "badge-staff" : "badge-viewer"}
                  = user.role
              %td
                - if user.active?
                  %span.badge.badge-active Active
                - else
                  %span.badge.badge-inactive Inactive
              %td
                = link_to user, class: "btn-ghost btn-ghost-primary me-1", title: "Show" do
                  %span.material-symbols{style: "font-size: 18px"} visibility
                = link_to edit_user_path(user), class: "btn-ghost btn-ghost-secondary me-1", title: "Edit" do
                  %span.material-symbols{style: "font-size: 18px"} edit
                = link_to user, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn-ghost btn-ghost-danger", title: "Delete" do
                  %span.material-symbols{style: "font-size: 18px"} delete
          - if @users.empty?
            %tr
              %td.text-muted.text-center{colspan: 6} No users found.
