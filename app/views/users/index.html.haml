.d-flex.justify-content-between.align-items-center.mb-3
  %h1 Users
  = link_to "New User", new_user_path, class: "btn btn-primary"

.card
  .card-body
    .table-responsive
      %table.table.table-hover.mb-0
        %thead
          %tr
            %th Username
            %th Email
            %th Name
            %th Role
            %th Active
            %th Actions
        %tbody
          - @users.each do |user|
            %tr
              %td= user.username
              %td= user.email
              %td= user.name
              %td
                %span.badge{class: user.admin? ? "bg-danger" : user.staff? ? "bg-primary" : "bg-secondary"}
                  = user.role
              %td
                - if user.active?
                  %span.badge.bg-success Active
                - else
                  %span.badge.bg-secondary Inactive
              %td
                = link_to "Show", user, class: "btn btn-sm btn-outline-primary me-1"
                = link_to "Edit", edit_user_path(user), class: "btn btn-sm btn-outline-secondary me-1"
                = link_to "Delete", user, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger"
          - if @users.empty?
            %tr
              %td.text-muted.text-center{colspan: 6} No users found.
