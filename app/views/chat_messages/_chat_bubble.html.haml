.chat-message.d-flex.mb-3{class: "chat-#{msg.role}"}
  .chat-bubble.rounded-3.px-3.py-2{class: "chat-bubble-#{msg.role}"}
    .chat-meta.d-flex.align-items-center.gap-2.mb-1
      %span.badge{class: msg.role == "user" ? "badge-active" : "badge-inactive"}
        = msg.role.capitalize
      %small.text-muted= msg.created_at.strftime("%b %d, %Y %H:%M:%S")
    - if msg.content.present?
      .chat-content= simple_format(msg.content)
