.d-flex.justify-content-between.align-items-center.mb-3
  %h5.mb-0.fw-semibold
    Conversation with
    - if @linked_user
      = link_to @linked_user.name, user_path(@linked_user)
    - else
      %code= @line_user_id
  .d-flex.align-items-center.gap-2
    - if @debug_mode
      %span.badge.badge-pending
        %span.material-symbols{style: "font-size: 14px; vertical-align: middle"} bug_report
        Debug mode
    = link_to "Back", chat_messages_path, class: "btn btn-outline-primary btn-sm"

.card
  .card-body.p-3
    .chat-history
      - messages_arr = @messages.to_a
      - i = 0
      - while i < messages_arr.length
        - msg = messages_arr[i]

        -# User and final assistant messages (assistant with content and no tool_calls)
        - if msg.role == "user" || (msg.role == "assistant" && msg.tool_calls.blank?)
          .chat-message.d-flex.mb-3{class: "chat-#{msg.role}"}
            .chat-bubble.rounded-3.px-3.py-2{class: "chat-bubble-#{msg.role}"}
              .chat-meta.d-flex.align-items-center.gap-2.mb-1
                %span.badge{class: msg.role == "user" ? "badge-active" : "badge-inactive"}
                  = msg.role.capitalize
                %small.text-muted= msg.created_at.strftime("%b %d, %Y %H:%M:%S")
              - if msg.content.present?
                .chat-content= simple_format(msg.content)
          - i += 1

        -# Tool-calling round: assistant with tool_calls, followed by tool result(s)
        - elsif msg.role == "assistant" && msg.tool_calls.present?
          - if @debug_mode
            -# Collect consecutive tool-call + tool-result messages in this round
            - round_msgs = [msg]
            - j = i + 1
            - while j < messages_arr.length && messages_arr[j].role == "tool"
              - round_msgs << messages_arr[j]
              - j += 1
            .chat-tool-chain.mb-3
              - msg.tool_calls.each do |tc|
                - tool_name = tc.dig("function", "name")
                - tool_args = tc.dig("function", "arguments")
                - tool_id = tc["id"]
                - tool_result_msg = round_msgs.find { |m| m.role == "tool" && m.tool_call_id == tool_id }
                .chat-tool-step.rounded-3.px-3.py-2.mb-2
                  .d-flex.align-items-center.gap-2.mb-1
                    %span.material-symbols{style: "font-size: 16px; vertical-align: middle"} build
                    %span.badge.badge-pending= tool_name
                    %small.text-muted= msg.created_at.strftime("%H:%M:%S")
                  %details
                    %summary.text-muted
                      %small Arguments
                    %pre.chat-tool-json.mt-1.mb-0
                      - begin
                        = JSON.pretty_generate(JSON.parse(tool_args.is_a?(String) ? tool_args : tool_args.to_json))
                      - rescue
                        = tool_args
                  - if tool_result_msg
                    %details.mt-2
                      %summary.text-muted
                        %small Result
                      %pre.chat-tool-json.mt-1.mb-0= tool_result_msg.content
            - i = j
          - else
            -# Skip tool-calling rounds in non-debug mode
            - i += 1
            - i += 1 while i < messages_arr.length && messages_arr[i].role == "tool"

        -# Skip standalone tool messages (shouldn't happen, but just in case)
        - else
          - i += 1

      - if messages_arr.select { |m| %w[user assistant].include?(m.role) }.empty?
        .text-muted.text-center No messages to display.
