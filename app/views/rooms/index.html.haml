.card{"data-controller" => "datatable"}
  .card-body.p-3
    .d-flex.justify-content-between.align-items-center.mb-3
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
        = resource_icon
        Rooms
      - if current_user.admin?
        = link_to new_room_path, class: "btn btn-primary btn-sm", data: { turbo_frame: "room_form" } do
          %span.material-symbols.me-1{style: "font-size: 16px; vertical-align: middle"} add
          New Room

    = turbo_frame_tag "room_form"

    .table-responsive
      %table.table.table-hover.mb-0{"data-datatable-target" => "table"}
        %thead
          %tr
            %th Building
            %th Room No
            %th Type
            %th Capacity
            %th Actions
        %tbody
          - @rooms.each do |room|
            %tr
              %td= room.building
              %td= room.room_number
              %td
                - if room.room_type.present?
                  %span.material-symbols.me-1{style: "font-size: 16px; vertical-align: middle"}= Room::ROOM_TYPE_ICONS[room.room_type]
                  = room.room_type.titleize
              %td= room.capacity
              %td
                - if current_user.admin?
                  = link_to edit_room_path(room), class: "btn-ghost btn-ghost-secondary me-1", title: "Edit", data: { turbo_frame: "room_form" } do
                    %span.material-symbols{style: "font-size: 18px"} edit
                  = link_to room_path(room), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn-ghost btn-ghost-danger", title: "Delete" do
                    %span.material-symbols{style: "font-size: 18px"} delete
