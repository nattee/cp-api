.card{"data-controller" => "datatable"}
  .card-body.p-3
    .d-flex.justify-content-between.align-items-center.mb-3
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
        = resource_icon
        Staff
      - if current_user.admin?
        = link_to "New Staff", new_staff_path, class: "btn btn-primary btn-sm"
    = form_with(url: staffs_path, method: :get, class: "row g-2 align-items-end mb-3", data: { turbo_frame: "_top" }) do
      .col-auto
        %label.form-label.mb-0{for: "status"} Status
        = select_tag :status, options_for_select([["Active", "active"], ["All", "all"]], params[:status] || "active"), class: "form-select form-select-sm", style: "width: 120px", onchange: "this.form.requestSubmit()"
      .col-auto
        %label.form-label.mb-0{for: "type"} Type
        = select_tag :type, options_for_select([["All", "all"], ["Lecturers", "lecturer"], ["Non-lecturers", "non_lecturer"]], params[:type] || "all"), class: "form-select form-select-sm", style: "width: 150px", onchange: "this.form.requestSubmit()"
    .table-responsive
      %table.table.table-hover.mb-0{"data-datatable-target" => "table"}
        %thead
          %tr
            %th Name
            %th Type
            %th Room
            %th Status
            %th Actions
        %tbody
          - @staffs.each do |staff|
            %tr
              %td= staff.display_name_th
              %td
                %span.badge{class: "badge-#{staff.staff_type.dasherize}"}= staff.staff_type.titleize
              %td= staff.room
              %td
                %span.badge{class: "badge-#{staff.status.dasherize}"}= staff.status.titleize
              %td
                = link_to staff, class: "btn-ghost btn-ghost-primary me-1", title: "Show" do
                  %span.material-symbols{style: "font-size: 18px"} visibility
                - if current_user.admin?
                  = link_to edit_staff_path(staff), class: "btn-ghost btn-ghost-secondary me-1", title: "Edit" do
                    %span.material-symbols{style: "font-size: 18px"} edit
                  = link_to staff, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn-ghost btn-ghost-danger", title: "Delete" do
                    %span.material-symbols{style: "font-size: 18px"} delete
