.card{"data-controller" => "datatable", "data-datatable-page-length-value" => "50"}
  .card-body.p-3
    .d-flex.align-items-center.mb-3
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
        = resource_icon
        Staff
      .d-flex.align-items-center.gap-4.mx-auto
        .d-flex.align-items-center.gap-2
          %span.form-label.mb-0.small.text-muted Status
          .btn-group.btn-group-sm
            - [["Active", "^(?!.*Retired)"], ["All", ""]].each_with_index do |(label, value), i|
              - checked = i == 0
              %input.btn-check{type: "radio", name: "filter-status", id: "filter-status-#{i}", value: value, checked: checked, "data-datatable-target" => "filter", "data-action" => "change->datatable#filter", "data-datatable-column-index" => "4", "data-datatable-regex" => "true", "data-datatable-default-value" => (checked ? value : nil)}
              %label.btn.btn-outline-secondary{for: "filter-status-#{i}"}= label
        .d-flex.align-items-center.gap-2
          %span.form-label.mb-0.small.text-muted Type
          .btn-group.btn-group-sm
            - [["All", ""], ["Lecturers", "^Lecturer$"], ["Non-lecturers", "^(?!Lecturer$)"]].each_with_index do |(label, value), i|
              - checked = i == 1
              %input.btn-check{type: "radio", name: "filter-type", id: "filter-type-#{i}", value: value, checked: checked, "data-datatable-target" => "filter", "data-action" => "change->datatable#filter", "data-datatable-column-index" => "2", "data-datatable-regex" => "true", "data-datatable-default-value" => (checked ? value : nil)}
              %label.btn.btn-outline-secondary{for: "filter-type-#{i}"}= label
      - if current_user.admin?
        = link_to "New Staff", new_staff_path, class: "btn btn-primary btn-sm"
    .table-responsive
      %table.table.table-hover.mb-0{"data-datatable-target" => "table"}
        %thead
          %tr
            %th Initials
            %th Name
            %th Type
            %th Room
            %th Status
            %th Actions
        %tbody
          - @staffs.each do |staff|
            %tr
              %td= staff.initials
              %td= staff.display_name_th
              %td
                %span.badge{class: "badge-#{staff.staff_type.dasherize}"}= staff.staff_type.titleize
              %td= staff.room
              %td
                %span.badge{class: "badge-#{staff.status.dasherize}"}= staff.status.titleize
              %td
                = link_to staff, class: "btn-ghost btn-ghost-primary me-1", title: "Show" do
                  %span.material-symbols{style: "font-size: 18px"} visibility
                - if current_user.admin?
                  = link_to edit_staff_path(staff), class: "btn-ghost btn-ghost-secondary me-1", title: "Edit" do
                    %span.material-symbols{style: "font-size: 18px"} edit
                  = link_to staff, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn-ghost btn-ghost-danger", title: "Delete" do
                    %span.material-symbols{style: "font-size: 18px"} delete
