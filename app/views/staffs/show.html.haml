.d-flex.justify-content-between.align-items-center.mb-3
  %h1= @staff.display_name_th
  .d-flex.gap-2
    - if current_user.admin?
      = link_to "Edit", edit_staff_path(@staff), class: "btn btn-outline-secondary"
    = link_to "Back", staffs_path, class: "btn btn-outline-primary"

.card
  .card-body
    .detail-section
      %dl.dl-fields.row.mb-0
        %dt.col-sm-3 Title
        %dd.col-sm-9= @staff.title

        - if @staff.academic_title.present?
          %dt.col-sm-3 Academic Title
          %dd.col-sm-9= @staff.academic_title

        %dt.col-sm-3 Name (EN)
        %dd.col-sm-9= @staff.full_name

        - if @staff.full_name_th.present?
          %dt.col-sm-3 Name (TH)
          %dd.col-sm-9= @staff.full_name_th

    .detail-section
      %h6.section-title Position
      %dl.dl-fields.row.mb-0
        %dt.col-sm-3 Type
        %dd.col-sm-9
          %span.badge{class: "badge-#{@staff.staff_type.dasherize}"}= @staff.staff_type.titleize

        %dt.col-sm-3 Status
        %dd.col-sm-9
          %span.badge{class: "badge-#{@staff.status.dasherize}"}= @staff.status.titleize

        - if @staff.employment_date.present?
          %dt.col-sm-3 Employment Date
          %dd.col-sm-9= @staff.employment_date.strftime("%B %-d, %Y")

    - if [@staff.email, @staff.phone, @staff.room].any?(&:present?)
      .detail-section
        %h6.section-title Contact
        %dl.dl-fields.row.mb-0
          - if @staff.email.present?
            %dt.col-sm-3 Email
            %dd.col-sm-9= @staff.email

          - if @staff.phone.present?
            %dt.col-sm-3 Phone
            %dd.col-sm-9= @staff.phone

          - if @staff.room.present?
            %dt.col-sm-3 Room
            %dd.col-sm-9= @staff.room

    - if @staff.birthdate.present?
      .detail-section
        %h6.section-title Personal
        %dl.dl-fields.row.mb-0
          %dt.col-sm-3 Birthdate
          %dd.col-sm-9= @staff.birthdate.strftime("%B %-d, %Y")

    - if @staff.staff_programs.any?
      .detail-section
        %h6.section-title Programs
        .table-responsive
          %table.table.table-hover.mb-0
            %thead
              %tr
                %th Program
                %th Role
                %th Start Date
                %th End Date
            %tbody
              - @staff.staff_programs.includes(:program).each do |sp|
                %tr
                  %td= link_to sp.program.name_en, sp.program
                  %td
                    - if sp.role.present?
                      %span.badge{class: "badge-#{sp.role.dasherize}"}= sp.role.titleize
                  %td= sp.start_date&.strftime("%B %-d, %Y")
                  %td= sp.end_date&.strftime("%B %-d, %Y")

    .detail-section
      %dl.dl-fields.row.mb-0
        %dt.col-sm-3 Created at
        %dd.col-sm-9= @staff.created_at.strftime("%B %d, %Y %H:%M")

        %dt.col-sm-3 Updated at
        %dd.col-sm-9= @staff.updated_at.strftime("%B %d, %Y %H:%M")

- if @teaching_semesters.any?
  .card.mt-3
    .card-body.p-3
      .d-flex.justify-content-between.align-items-center.mb-3
        %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
          %span.material-symbols.resource-icon.me-2 school
          Teaching
        = form_with(url: staff_path(@staff), method: :get, class: "d-flex align-items-center gap-2") do |f|
          %label.form-label.mb-0.small.text-muted Semester
          = select_tag :semester_id, options_for_select(@teaching_semesters.map { |s| ["#{s.display_name} — #{Semester::SEMESTER_LABELS[s.semester_number]}", s.id] }, @selected_semester&.id), class: "form-select form-select-sm", style: "width: auto", data: { controller: "select2" }, onchange: "this.form.requestSubmit()"

      - if @teachings.any?
        .table-responsive
          %table.table.table-hover.mb-0
            %thead
              %tr
                %th Course No
                %th Course Name
                %th Section
                %th.text-center Load Ratio
            %tbody
              - @teachings.each do |teaching|
                - offering = teaching.section.course_offering
                %tr
                  %td= link_to offering.course.course_no, offering.course
                  %td= offering.course.name
                  %td= teaching.section.section_number
                  %td.text-center= teaching.load_ratio
      - else
        %p.text-muted.mb-0 No teaching assignments for this semester.

      %p.text-muted.small.mt-2.mb-0
        = link_to "Department-wide teaching matrix for #{@selected_semester.display_name} →", schedules_teaching_matrix_path(year: @selected_semester.year_be, semester_number: @selected_semester.semester_number)

- if @teaching_history
  .card.mt-3
    .card-body.p-3
      %h5.card-title.fw-semibold.d-flex.align-items-center.mb-3
        %span.material-symbols.resource-icon.me-2 history_edu
        Teaching History
      .table-responsive
        %table.table.table-hover.mb-0.teaching-history-table
          %thead
            %tr
              %th Term
              - @teaching_history.courses.each do |c|
                %th.th-rotated
                  = link_to c[:course_no], c[:course], title: c[:name]
          %tbody
            - @teaching_history.semesters.each do |sem|
              %tr
                %th{scope: "row"}= sem.display_name
                - @teaching_history.courses.each do |c|
                  - secs = @teaching_history.cells[[ sem.id, c[:course_no] ]]
                  %td.text-center{title: secs && "Section#{"s" if secs.size > 1} #{secs.join(", ")}"}= secs&.size
      - if @teaching_history.capped
        %p.text-muted.small.mt-2.mb-0
          Showing the last 20 years —
          = link_to "Show all", staff_path(@staff, history: "all")
