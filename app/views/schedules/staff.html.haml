.d-flex.justify-content-between.align-items-center.mb-3
  %h1.d-flex.align-items-center
    %span.material-symbols.resource-icon.me-2 person
    Staff Schedule
  = link_to "Back", schedules_path, class: "btn btn-outline-primary"

.card.mb-3
  .card-body.p-3
    = form_with(url: schedules_staff_path, method: :get, class: "row g-2 align-items-end") do |f|
      .col-md-4
        %label.form-label.mb-0 Semester
        = select_tag :semester_id, options_for_select(@semesters.map { |s| ["#{s.display_name} — #{Semester::SEMESTER_LABELS[s.semester_number]}", s.id] }, params[:semester_id]), include_blank: "Select semester", class: "form-select form-select-sm", data: { controller: "select2" }
      .col-md-4
        %label.form-label.mb-0 Staff
        = select_tag :staff_id, options_for_select(@staffs.map { |s| [s.display_name_th, s.id] }, params[:staff_id]), include_blank: "Select staff", class: "form-select form-select-sm", data: { controller: "select2" }
      .col-auto
        %button.btn.btn-primary.btn-sm{type: "submit"}
          %span.material-symbols{style: "font-size: 16px; vertical-align: middle"} filter_list
          View

- if @entries
  - if @entries.any?
    .card.mb-3
      .card-body.p-3
        %h5.card-title.mb-3.fw-semibold
          = @staff_member.display_name_th
          %small.text-muted= "— #{@semester.display_name} #{Semester::SEMESTER_LABELS[@semester.semester_number]}"
        = render "shared/week_calendar", entries: @entries

    .card
      .card-body.p-3
        %h6.section-title Load Summary
        %dl.dl-fields.row.mb-0
          %dt.col-sm-3 Total Load Ratio
          %dd.col-sm-9
            %strong= @total_load
  - else
    .card
      .card-body.p-3
        %p.text-muted.mb-0 No teaching assignments found for this staff and semester.
