.d-flex.justify-content-between.align-items-center.mb-3
  %h1.d-flex.align-items-center
    %span.material-symbols.resource-icon.me-2 warning
    Conflict Detection
  = link_to "Back", schedules_path, class: "btn btn-outline-primary"

.card.mb-3
  .card-body.p-3
    = form_with(url: schedules_conflicts_path, method: :get, class: "row g-2 align-items-end") do |f|
      .col-md-4
        %label.form-label.mb-0 Semester
        = select_tag :semester_id, options_for_select(@semesters.map { |s| ["#{s.display_name} — #{Semester::SEMESTER_LABELS[s.semester_number]}", s.id] }, params[:semester_id]), include_blank: "Select semester", class: "form-select form-select-sm", data: { controller: "select2" }
      .col-auto
        %label.form-label.mb-0 Conflict Type
        .btn-group.btn-group-sm
          - [["Both", "both"], ["Room", "room"], ["Staff", "staff"]].each do |label, value|
            - checked = @conflict_type == value
            %input.btn-check{type: "radio", name: "conflict_type", id: "conflict-#{value}", value: value, checked: checked, autocomplete: "off"}
            %label.btn.btn-outline-secondary{for: "conflict-#{value}"}= label
      .col-auto
        %button.btn.btn-primary.btn-sm{type: "submit"}
          %span.material-symbols{style: "font-size: 16px; vertical-align: middle"} filter_list
          Check

- if @conflicts
  .card
    .card-body.p-3
      %h5.card-title.mb-3.fw-semibold
        = @semester.display_name
        %small.text-muted= "— #{Semester::SEMESTER_LABELS[@semester.semester_number]} Semester"
        - if @conflicts.any?
          %span.badge.bg-danger.ms-2= "#{@conflicts.size} conflict#{'s' if @conflicts.size != 1}"
        - else
          %span.badge.badge-active.ms-2 No conflicts

      - if @conflicts.any?
        .table-responsive
          %table.table.table-hover.mb-0
            %thead
              %tr
                %th Type
                %th Day
                %th Time
                %th Conflict
                %th Details
            %tbody
              - @conflicts.each do |c|
                %tr
                  %td
                    - if c[:type] == "Room"
                      %span.badge.badge-lecturer= c[:type]
                    - else
                      %span.badge.badge-adjunct= c[:type]
                  %td= c[:day]
                  %td= c[:time]
                  %td= c[:conflict]
                  %td= c[:details]
      - else
        %p.text-muted.mb-0 No scheduling conflicts detected.
