.d-flex.justify-content-between.align-items-center.mb-3
  %h1.d-flex.align-items-center
    %span.material-symbols.resource-icon.me-2 school
    Student Timetable
  = link_to "Back", schedules_path, class: "btn btn-outline-primary"

.card.mb-3
  .card-body.p-3
    = form_with(url: schedules_student_path, method: :get, class: "row g-2 align-items-end") do |f|
      .col-md-4
        %label.form-label.mb-0 Semester
        = select_tag :semester_id, options_for_select(@semesters.map { |s| ["#{s.display_name} — #{Semester::SEMESTER_LABELS[s.semester_number]}", s.id] }, params[:semester_id]), include_blank: "Select semester", class: "form-select form-select-sm", data: { controller: "select2" }
      .col-md-4
        %label.form-label.mb-0 Student
        = select_tag :student_id, options_for_select(@students.map { |s| ["#{s.student_id} — #{s.display_name}", s.id] }, params[:student_id]), include_blank: "Select student", class: "form-select form-select-sm", data: { controller: "select2" }
      .col-auto
        %button.btn.btn-primary.btn-sm{type: "submit"}
          %span.material-symbols{style: "font-size: 16px; vertical-align: middle"} filter_list
          View

- if @entries
  - if @entries.any?
    .card.mb-3
      .card-body.p-3
        %h5.card-title.mb-3.fw-semibold
          = "#{@student.student_id} #{@student.display_name}"
          %small.text-muted= "— #{@semester.display_name} #{Semester::SEMESTER_LABELS[@semester.semester_number]}"
        = render "shared/week_calendar", entries: @entries

  - if @schedule_entries&.any?
    .card
      .card-body.p-3
        %h6.section-title Enrolled Courses
        .table-responsive
          %table.table.table-hover.mb-0
            %thead
              %tr
                %th Course No
                %th Course Name
                %th Section
                %th.text-center Credits
                %th.text-center Grade
            %tbody
              - @schedule_entries.each do |entry|
                %tr
                  %td= link_to entry[:grade].course.course_no, entry[:grade].course
                  %td= entry[:grade].course.name
                  %td
                    - if entry[:section]
                      = entry[:section].section_number
                    - else
                      %span.text-muted —
                  %td.text-center= entry[:grade].course.credits
                  %td.text-center
                    - if entry[:grade].grade.present?
                      %span.badge{class: entry[:grade].grade_badge_class}= entry[:grade].grade

  - if @entries.empty? && @schedule_entries.blank?
    .card
      .card-body.p-3
        %p.text-muted.mb-0 No grades found for this student and semester.
  - elsif @entries.empty? && @schedule_entries.any?
    .card.mb-3
      .card-body.p-3
        %p.text-muted.mb-0 No schedule data available. The student has grades but no course offerings exist for this semester.
