.card{"data-controller" => "datatable", "data-datatable-server-side-url-value" => datatable_students_path}
  .card-body.p-3
    .d-flex.align-items-center.mb-3
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
        = resource_icon
        Students
      .d-flex.align-items-center.gap-4.mx-auto
        .d-flex.align-items-center.gap-2{style: "min-width: 320px"}
          %span.form-label.mb-0.small.text-muted Program
          = select_tag "filter-program", options_for_select([["All", ""]] + @programs.map { |p| [p, p] }), data: { controller: "select2", datatable_target: "filter", action: "change->datatable#filter", datatable_column_index: "2" }
        .d-flex.align-items-center.gap-2{style: "min-width: 160px"}
          %span.form-label.mb-0.small.text-muted Year
          = select_tag "filter-year", options_for_select([["All", ""]] + @admission_years.map { |y| [y, y] }), data: { controller: "select2", datatable_target: "filter", action: "change->datatable#filter", datatable_column_index: "3" }
      - if current_user.admin?
        = link_to "New Student", new_student_path, class: "btn btn-primary btn-sm"
    .table-responsive
      %table.table.table-hover.mb-0{"data-datatable-target" => "table"}
        %thead
          %tr
            %th Student ID
            %th Name
            %th Program
            %th Admission Year
            %th Status
            %th Actions
        %tbody
