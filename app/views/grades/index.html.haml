.card.mb-3
  .card-body.p-3
    .d-flex.justify-content-between.align-items-center.mb-3
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
        = resource_icon
        Grades
      - if current_user.admin?
        = link_to "New Grade", new_grade_path, class: "btn btn-primary btn-sm"
    = form_with(url: grades_path, method: :get, class: "row g-2 align-items-end") do |f|
      .col-auto
        %label.form-label.mb-0{for: "year"} Year
        = select_tag :year, options_for_select(@available_years, params[:year]), include_blank: "Select year", class: "form-select form-select-sm", style: "width: 120px"
      .col-auto
        %label.form-label.mb-0{for: "semester"} Semester
        = select_tag :semester, options_for_select(Grade::SEMESTERS, params[:semester]&.to_i), include_blank: "All", class: "form-select form-select-sm", style: "width: 120px"
      .col-auto
        %button.btn.btn-outline-primary.btn-sm{type: "submit"}
          %span.material-symbols{style: "font-size: 16px; vertical-align: middle"} filter_list
          Filter

- if @filtered
  .card{"data-controller" => "datatable"}
    .card-body.p-3
      .table-responsive
        %table.table.table-hover.mb-0{"data-datatable-target" => "table"}
          %thead
            %tr
              %th Student ID
              %th Student Name
              %th Course No
              %th Course Name
              %th Grade
              %th Weight
              %th Source
              %th Actions
          %tbody
            - @grades.each do |grade|
              %tr
                %td= grade.student.student_id
                %td= grade.student.display_name
                %td= grade.course.course_no
                %td= grade.course.name
                %td
                  - if grade.grade.present?
                    %span.badge{class: grade.grade_badge_class}= grade.grade
                %td= grade.grade_weight
                %td
                  %span.badge{class: "badge-#{grade.source}"}= grade.source.titleize
                %td
                  = link_to grade, class: "btn-ghost btn-ghost-primary me-1", title: "Show" do
                    %span.material-symbols{style: "font-size: 18px"} visibility
                  - if current_user.admin?
                    - if grade.manual?
                      = link_to edit_grade_path(grade), class: "btn-ghost btn-ghost-secondary me-1", title: "Edit" do
                        %span.material-symbols{style: "font-size: 18px"} edit
                    = link_to grade, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn-ghost btn-ghost-danger", title: "Delete" do
                      %span.material-symbols{style: "font-size: 18px"} delete
            - if @grades.empty?
              %tr
                %td.text-muted.text-center{colspan: 8} No grades found for this term.
- elsif params[:year].present? || params[:semester].present?
  .text-muted.mt-3 Please select both year and semester to filter grades.
