!!!
%html{"data-bs-theme" => "dark"}
  %head
    %title= content_for(:title) || "CP API"
    %meta{name: "viewport", content: "width=device-width,initial-scale=1"}
    %meta{name: "apple-mobile-web-app-capable", content: "yes"}
    %meta{name: "application-name", content: "CP API"}
    %meta{name: "mobile-web-app-capable", content: "yes"}
    = csrf_meta_tags
    = csp_meta_tag

    = yield :head

    %link{rel: "icon", href: "/icon.png", type: "image/png"}
    %link{rel: "icon", href: "/icon.svg", type: "image/svg+xml"}
    %link{rel: "apple-touch-icon", href: "/icon.png"}

    = stylesheet_link_tag "select2.min", "data-turbo-track": "reload"
    = stylesheet_link_tag "select2-bootstrap-5-theme.min", "data-turbo-track": "reload"
    = stylesheet_link_tag "flatpickr", "data-turbo-track": "reload"
    = stylesheet_link_tag "datatables.bootstrap5.min", "data-turbo-track": "reload"
    = stylesheet_link_tag :app, "data-turbo-track": "reload"
    = stylesheet_link_tag "material-symbols", "data-turbo-track": "reload"
    = javascript_include_tag "datatables", "data-turbo-track": "reload"
    = javascript_include_tag "select2.min", "data-turbo-track": "reload"
    = javascript_importmap_tags

  %body
    .d-flex
      -# Sidebar - offcanvas on small screens, fixed on large
      %nav#sidebar.offcanvas-lg.offcanvas-start.d-flex.flex-column.flex-shrink-0.p-3.bg-body-tertiary{style: "width: 250px; min-height: 100vh;"}
        .offcanvas-header.d-lg-none
          %h5.offcanvas-title CP API
          %button.btn-close{"data-bs-dismiss" => "offcanvas", "data-bs-target" => "#sidebar", "aria-label" => "Close"}
        %a.d-flex.align-items-center.mb-3.mb-md-0.me-md-auto.text-decoration-none.d-none.d-lg-flex{href: root_path}
          %span.fs-4.fw-semibold CP API
        %hr.d-none.d-lg-block
        %ul.nav.nav-pills.flex-column.mb-auto
          %li.nav-item
            = link_to programs_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'programs'}" do
              = resource_icon("programs")
              Programs
          %li.nav-item
            = link_to courses_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'courses'}" do
              = resource_icon("courses")
              Courses
          %li.nav-item
            = link_to staffs_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'staffs'}" do
              = resource_icon("staffs")
              Staff
          %li.nav-item
            = link_to students_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'students'}" do
              = resource_icon("students")
              Students
          %li.nav-item
            = link_to grades_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'grades'}" do
              = resource_icon("grades")
              Grades
          %li.nav-item
            = link_to users_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'users'}" do
              = resource_icon("users")
              Users

          %li.mt-3.mb-1.px-3
            %small.text-uppercase.fw-semibold.text-body-secondary.letter-spacing-wide Teaching
          %li.nav-item
            = link_to semesters_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'semesters'}" do
              = resource_icon("semesters")
              Semesters
          %li.nav-item
            = link_to rooms_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'rooms'}" do
              = resource_icon("rooms")
              Rooms
          %li.nav-item
            = link_to scrapes_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'scrapes'}" do
              = resource_icon("scrapes")
              Scraper
          %li.nav-item
            = link_to schedules_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'schedules'}" do
              = resource_icon("schedules")
              Schedules

          %li.nav-item
            = link_to line_account_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'line_accounts'}" do
              = resource_icon("line_accounts")
              LINE Account

          - if current_user.admin?
            %li.mt-3.mb-1.px-3
              %small.text-uppercase.fw-semibold.text-body-secondary.letter-spacing-wide Admin
            %li.nav-item
              = link_to chat_messages_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'chat_messages'}" do
                = resource_icon("chat_messages")
                Chat History
            %li.nav-item
              = link_to data_imports_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'data_imports'}" do
                = resource_icon("data_imports")
                Imports
            %li.nav-item
              = link_to api_events_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'api_events'}" do
                = resource_icon("api_events")
                API Events
                - error_count = ApiEvent.errors_since(24.hours.ago).count
                - if error_count > 0
                  %span.badge.bg-danger.ms-auto= error_count
            %li.nav-item
              = link_to dev_styleguide_path, class: "nav-link d-flex align-items-center #{'active' if controller_name == 'dev'}" do
                = resource_icon("dev")
                Style Guide

        %hr
        .dropdown
          %a.d-flex.align-items-center.text-decoration-none.dropdown-toggle{"data-bs-toggle" => "dropdown", href: "#"}
            %span= current_user.name
          %ul.dropdown-menu.dropdown-menu-dark.shadow
            %li= link_to "Profile", user_path(current_user), class: "dropdown-item"
            %li
              %hr.dropdown-divider
            %li= button_to "Sign Out", logout_path, method: :delete, class: "dropdown-item", data: { turbo: false }

      -# Main content
      .flex-grow-1.d-flex.flex-column{style: "min-height: 100vh;"}
        %header.navbar.bg-body-tertiary.d-lg-none.border-bottom
          .container-fluid
            %button.navbar-toggler{"data-bs-toggle" => "offcanvas", "data-bs-target" => "#sidebar", "aria-controls" => "sidebar"}
              %span.navbar-toggler-icon
            %span.navbar-brand.mb-0 CP API

        %main.flex-grow-1.p-4
          .container-fluid
            - if flash[:notice]
              .alert.alert-success.alert-dismissible.fade.show{"data-controller" => "alert", role: "alert"}
                = flash[:notice]
                %button.btn-close{"data-action" => "alert#dismiss", "aria-label" => "Close"}
            - if flash[:alert]
              .alert.alert-danger.alert-dismissible.fade.show{"data-controller" => "alert", role: "alert"}
                = flash[:alert]
                %button.btn-close{"data-action" => "alert#dismiss", "aria-label" => "Close"}

            = yield
