.d-flex.justify-content-between.align-items-center.mb-3
  %h1= @program.name_en
  .d-flex.gap-2
    - if current_user.admin?
      = link_to "Edit", edit_program_path(@program), class: "btn btn-outline-secondary"
    = link_to "Back", program_group_path(@program.program_group), class: "btn btn-outline-primary"

.card
  .card-body
    .detail-section
      %dl.dl-fields.row.mb-0
        %dt.col-sm-3 Program Group
        %dd.col-sm-9= link_to @program.program_group.display_name, @program.program_group

        %dt.col-sm-3 Program Code
        %dd.col-sm-9= @program.program_code

        %dt.col-sm-3 Short Name
        %dd.col-sm-9= @program.short_name.presence || "—"

        %dt.col-sm-3 Name (EN)
        %dd.col-sm-9= @program.name_en

        - if @program.name_th.present?
          %dt.col-sm-3 Name (TH)
          %dd.col-sm-9= @program.name_th

    .detail-section
      %h6.section-title Degree
      %dl.dl-fields.row.mb-0
        %dt.col-sm-3 Degree Level
        %dd.col-sm-9
          %span.badge{class: "badge-#{@program.degree_level}"}= @program.degree_level.titleize

        %dt.col-sm-3 Degree Name (EN)
        %dd.col-sm-9= @program.degree_name

        - if @program.degree_name_th.present?
          %dt.col-sm-3 Degree Name (TH)
          %dd.col-sm-9= @program.degree_name_th

        %dt.col-sm-3 Field of Study
        %dd.col-sm-9= @program.field_of_study

        %dt.col-sm-3 Total Credits
        %dd.col-sm-9= @program.total_credit || "—"

        %dt.col-sm-3
          Year Started (B.E.)
          %button.help-popover-trigger{type: "button", tabindex: "0"}
            %span.material-symbols{style: "font-size: 16px"} help
            %span.help-popover-content Buddhist Era year (B.E.). To convert to CE, subtract 543.
        %dd.col-sm-9= @program.year_started_be

        %dt.col-sm-3 Status
        %dd.col-sm-9
          %span.badge{class: @program.active? ? "badge-active" : "badge-inactive"}= @program.active? ? "Active" : "Inactive"

    .detail-section
      %dl.dl-fields.row.mb-0
        %dt.col-sm-3 Created at
        %dd.col-sm-9= @program.created_at.strftime("%B %d, %Y %H:%M")

        %dt.col-sm-3 Updated at
        %dd.col-sm-9= @program.updated_at.strftime("%B %d, %Y %H:%M")

.card.mt-3{"data-controller" => "course-filter", "data-course-filter-mode-value" => "rows", "data-course-filter-fixed-program-value" => @program.program_code}
  .card-body.p-3
    .d-flex.align-items-center.mb-3.gap-3.flex-wrap
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
        = resource_icon("courses")
        Curriculum
        %span.text-muted.ms-2.fw-normal
          (#{@curriculum.values.sum(&:size)})
      - if @curriculum.any?
        -# Default to All here: a program's curriculum legitimately spans gen-ed,
        -# math and language courses outside the 2110 department prefix.
        = render "shared/course_filters", fixed_program: @program.program_code, scope_default: ""
      - if current_user.admin?
        = link_to new_program_program_course_path(@program), class: "btn btn-primary btn-sm ms-auto", data: { turbo_frame: "program_course_form" } do
          %span.material-symbols.me-1{style: "font-size: 16px; vertical-align: middle"} add
          Add Course

    = turbo_frame_tag "program_course_form"

    - if @curriculum.any?
      .table-responsive
        %table.table.table-hover.mb-0
          %thead
            %tr
              %th Course No
              %th Name
              %th.text-center Rev. Year
              %th.text-center Credits
              %th Actions
          %tbody
            - @curriculum.each_with_index do |(code, pairings), idx|
              - if idx.positive?
                %tr.table-group-spacer{"aria-hidden" => "true", "data-course-filter-target" => "groupRow", "data-course-group" => code.to_s}
                  %td{colspan: 5}
              %tr.table-group-header{"data-course-filter-target" => "groupRow", "data-course-group" => code.to_s}
                %td{colspan: 5}
                  %strong= ProgramCourse.group_label(code)
                  - if code.present?
                    %span.text-muted.ms-2.fw-normal= code
                  %span.text-muted.ms-2.fw-normal
                    (#{pairings.size})
              - pairings.each do |pc|
                %tr{"data-course-filter-target" => "row", "data-course-no" => pc.course.course_no, "data-course-tokens" => "#{@program.program_code}-#{ProgramCourse.filter_type(pc.course_group_code)}", "data-course-group" => code.to_s}
                  %td= link_to pc.course.course_no, pc.course
                  %td= pc.course.name
                  %td.text-center= pc.course.revision_year_be
                  %td.text-center= pc.course.credits
                  %td
                    = link_to pc.course, class: "btn-ghost btn-ghost-primary me-1", title: "Show" do
                      %span.material-symbols{style: "font-size: 18px"} visibility
                    - if current_user.admin?
                      = link_to edit_program_program_course_path(@program, pc), class: "btn-ghost btn-ghost-secondary me-1", title: "Edit", data: { turbo_frame: "program_course_form" } do
                        %span.material-symbols{style: "font-size: 18px"} edit
                      = link_to program_program_course_path(@program, pc), data: { turbo_method: :delete, turbo_confirm: "Remove #{pc.course.course_no} from this program?" }, class: "btn-ghost btn-ghost-danger", title: "Remove" do
                        %span.material-symbols{style: "font-size: 18px"} delete
    - else
      %p.text-muted.mb-0 No courses linked to this program.

- if @admission_chart_data || @gpa_chart_data
  - admission_col_class = @gpa_chart_data ? "col-lg-7 mb-3 mb-lg-0" : "col-lg-12"
  - gpa_col_class = @admission_chart_data ? "col-lg-5" : "col-lg-12"
  .row.mt-3
    - if @admission_chart_data
      %div{class: admission_col_class}
        .card.h-100{"data-controller" => "chart", "data-chart-type-value" => "stacked-bar",
                     "data-chart-data-value" => @admission_chart_data.to_json}
          .card-body.p-3
            .d-flex.justify-content-between.align-items-center.mb-3
              %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
                %span.material-symbols.resource-icon.me-2 bar_chart
                Students by Admission Year
              %select.form-select.form-select-sm{"data-chart-target" => "filter",
                      "data-action" => "change->chart#filterChanged",
                      style: "width: auto"}
                %option{value: "all"} All Statuses
                - Student::STATUSES.each do |s|
                  %option{value: s}= s.titleize
            %div{style: "height: 300px"}
              %canvas{"data-chart-target" => "canvas"}

    - if @gpa_chart_data
      %div{class: gpa_col_class}
        .card.h-100{"data-controller" => "chart", "data-chart-type-value" => "histogram",
                     "data-chart-data-value" => @gpa_chart_data.to_json}
          .card-body.p-3
            %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center.mb-3
              %span.material-symbols.resource-icon.me-2 equalizer
              GPA Distribution
            %div{style: "height: 300px"}
              %canvas{"data-chart-target" => "canvas"}

- if current_user.can?("students.read_minimal")
  .card.mt-3{"data-controller" => "datatable"}
    .card-body.p-3
      .d-flex.justify-content-between.align-items-center.mb-3
        %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
          %span.material-symbols.resource-icon.me-2 school
          Students
          %span.text-muted.ms-2.fw-normal
            (#{@students.size})
      - if @students.any?
        .table-responsive
          %table.table.table-hover.mb-0{"data-datatable-target" => "table"}
            %thead
              %tr
                %th Student ID
                %th Name
                %th Admission Year (B.E.)
                - if current_user.can?("students.read_full")
                  %th Status
                %th Actions
            %tbody
              - @students.each do |student|
                %tr
                  %td= student.student_id
                  %td= student.display_name
                  %td= student.admission_year_be
                  - if current_user.can?("students.read_full")
                    %td
                      %span.badge{class: "badge-#{student.status.dasherize}"}= student.status.titleize
                  %td
                    = link_to student, class: "btn btn-ghost btn-ghost-primary btn-sm" do
                      %span.material-symbols{style: "font-size: 18px"} visibility
      - else
        %p.text-muted.mb-0 No students enrolled in this program.
