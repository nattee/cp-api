.d-flex.justify-content-between.align-items-center.mb-3
  %h1= @program.name_en
  .d-flex.gap-2
    - if current_user.admin?
      = link_to "Edit", edit_program_path(@program), class: "btn btn-outline-secondary"
    = link_to "Back", programs_path, class: "btn btn-outline-primary"

.card
  .card-body
    .detail-section
      %dl.dl-fields.row.mb-0
        %dt.col-sm-3 Program Code
        %dd.col-sm-9= @program.program_code

        %dt.col-sm-3 Short Name
        %dd.col-sm-9= @program.short_name.presence || "—"

        %dt.col-sm-3 Name (EN)
        %dd.col-sm-9= @program.name_en

        - if @program.name_th.present?
          %dt.col-sm-3 Name (TH)
          %dd.col-sm-9= @program.name_th

    .detail-section
      %h6.section-title Degree
      %dl.dl-fields.row.mb-0
        %dt.col-sm-3 Degree Level
        %dd.col-sm-9
          %span.badge{class: "badge-#{@program.degree_level}"}= @program.degree_level.titleize

        %dt.col-sm-3 Degree Name (EN)
        %dd.col-sm-9= @program.degree_name

        - if @program.degree_name_th.present?
          %dt.col-sm-3 Degree Name (TH)
          %dd.col-sm-9= @program.degree_name_th

        %dt.col-sm-3 Field of Study
        %dd.col-sm-9= @program.field_of_study

        %dt.col-sm-3 Total Credits
        %dd.col-sm-9= @program.total_credit || "—"

        %dt.col-sm-3
          Year Started
          %button.help-popover-trigger{type: "button", tabindex: "0"}
            %span.material-symbols{style: "font-size: 16px"} help
            %span.help-popover-content Buddhist Era year (B.E.). To convert to CE, subtract 543.
        %dd.col-sm-9= @program.year_started

        %dt.col-sm-3 Status
        %dd.col-sm-9
          %span.badge{class: @program.active? ? "badge-active" : "badge-inactive"}= @program.active? ? "Active" : "Inactive"

    .detail-section
      %dl.dl-fields.row.mb-0
        %dt.col-sm-3 Created at
        %dd.col-sm-9= @program.created_at.strftime("%B %d, %Y %H:%M")

        %dt.col-sm-3 Updated at
        %dd.col-sm-9= @program.updated_at.strftime("%B %d, %Y %H:%M")

- if @students.any?
  .row.mt-3
    .col-lg-7.mb-3.mb-lg-0
      .card.h-100{"data-controller" => "chart", "data-chart-type-value" => "stacked-bar",
                   "data-chart-data-value" => @admission_chart_data.to_json}
        .card-body.p-3
          .d-flex.justify-content-between.align-items-center.mb-3
            %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
              %span.material-symbols.resource-icon.me-2 bar_chart
              Students by Admission Year
            %select.form-select.form-select-sm{"data-chart-target" => "filter",
                    "data-action" => "change->chart#filterChanged",
                    style: "width: auto"}
              %option{value: "all"} All Statuses
              - Student::STATUSES.each do |s|
                %option{value: s}= s.titleize
          %div{style: "height: 300px"}
            %canvas{"data-chart-target" => "canvas"}

    .col-lg-5
      .card.h-100{"data-controller" => "chart", "data-chart-type-value" => "histogram",
                   "data-chart-data-value" => @gpa_chart_data.to_json}
        .card-body.p-3
          %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center.mb-3
            %span.material-symbols.resource-icon.me-2 equalizer
            GPA Distribution
          %div{style: "height: 300px"}
            %canvas{"data-chart-target" => "canvas"}

.card.mt-3{"data-controller" => "datatable"}
  .card-body.p-3
    .d-flex.justify-content-between.align-items-center.mb-3
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
        %span.material-symbols.resource-icon.me-2 school
        Students
        %span.text-muted.ms-2.fw-normal
          (#{@students.size})
    - if @students.any?
      .table-responsive
        %table.table.table-hover.mb-0{"data-datatable-target" => "table"}
          %thead
            %tr
              %th Student ID
              %th Name
              %th Admission Year
              %th Status
              %th Actions
          %tbody
            - @students.each do |student|
              %tr
                %td= student.student_id
                %td= student.full_name
                %td= student.admission_year_be
                %td
                  %span.badge{class: "badge-#{student.status.dasherize}"}= student.status.titleize
                %td
                  = link_to student, class: "btn btn-ghost btn-ghost-primary btn-sm" do
                    %span.material-symbols{style: "font-size: 18px"} visibility
    - else
      %p.text-muted.mb-0 No students enrolled in this program.
