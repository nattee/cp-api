= form_with(model: program, class: "needs-validation") do |f|
  - if program.errors.any?
    .alert.alert-danger
      %h5.alert-heading
        = pluralize(program.errors.count, "error")
        prohibited this program from being saved:
      %ul.mb-0
        - program.errors.full_messages.each do |message|
          %li= message

  %fieldset.form-section
    %legend Program Info
    .row
      .col-md-6.mb-3
        = f.label :program_group_id, "Program Group", class: "form-label"
        = f.select :program_group_id, options_for_select(ProgramGroup.where.not(code: "OTHER").order(:id).map { |g| [g.display_name, g.id] }, program.program_group_id), { include_blank: "Select a group" }, class: "form-select #{'is-invalid' if program.errors[:program_group].any?}", data: { controller: "select2" }
        - if program.errors[:program_group].any?
          .invalid-feedback= program.errors[:program_group].first
      .col-md-6.mb-3
        = f.label :program_code, "Program Code", class: "form-label"
        %button.help-popover-trigger{type: "button", tabindex: "0"}
          %span.material-symbols{style: "font-size: 16px"} help
          %span.help-popover-content 4-digit code identifying this program revision. Used for student imports.
        .input-group
          %span.input-group-text
            %span.material-symbols pin
          = f.text_field :program_code, class: "form-control #{'is-invalid' if program.errors[:program_code].any?}", maxlength: 4
          - if program.errors[:program_code].any?
            .invalid-feedback= program.errors[:program_code].first
    .row
      .col-md-6.mb-3
        = f.label :short_name, "Short Name", class: "form-label"
        .input-group
          %span.input-group-text
            %span.material-symbols label
          = f.text_field :short_name, class: "form-control"
      .col-md-6.mb-3
        = f.label :alternative_program_code, "Alternative Program Code", class: "form-label"
        %button.help-popover-trigger{type: "button", tabindex: "0"}
          %span.material-symbols{style: "font-size: 16px"} help
          %span.help-popover-content Alternative code from external systems (e.g. 5-digit MAJORCODE from the registration system). Used as fallback when matching during student imports.
        .input-group
          %span.input-group-text
            %span.material-symbols tag
          = f.text_field :alternative_program_code, class: "form-control"

  %fieldset.form-section
    %legend Revision Details
    .row
      .col-md-6.mb-3
        = f.label :total_credit, "Total Credits", class: "form-label"
        .input-group
          %span.input-group-text
            %span.material-symbols school
          = f.number_field :total_credit, class: "form-control #{'is-invalid' if program.errors[:total_credit].any?}"
          - if program.errors[:total_credit].any?
            .invalid-feedback= program.errors[:total_credit].first
      .col-md-6.mb-3
        = f.label :year_started, "Year Started", class: "form-label"
        %button.help-popover-trigger{type: "button", tabindex: "0"}
          %span.material-symbols{style: "font-size: 16px"} help
          %span.help-popover-content Buddhist Era year (e.g. 2540). To convert from CE, add 543.
        .input-group
          %span.input-group-text
            %span.material-symbols calendar_month
          = f.number_field :year_started, class: "form-control #{'is-invalid' if program.errors[:year_started].any?}"
          - if program.errors[:year_started].any?
            .invalid-feedback= program.errors[:year_started].first
    .row
      .col-md-6.mb-3
        = f.label :active, class: "form-label d-block"
        .form-check.form-switch
          = f.check_box :active, class: "form-check-input", role: "switch"
          = f.label :active, "Active program", class: "form-check-label"

  = f.submit class: "btn btn-primary"
