.row.justify-content-center
  .col-lg-8.col-xl-6
    .card
      .card-body.p-3
        .d-flex.justify-content-between.align-items-center.mb-3
          %h5.card-title.mb-0
            = resource_icon("chats")
            Chat Playground
          = link_to chat_path, data: { turbo_method: :post, turbo_frame: "_top" }, params: { message: "/clear" }, class: "btn btn-sm btn-outline-secondary" do
            %span.material-symbols{style: "font-size: 16px; vertical-align: middle;"} delete
            Clear

        .chat-messages{style: "max-height: 60vh; overflow-y: auto;", "data-controller" => "scroll-bottom"}
          - if @messages.empty?
            .text-center.text-body-secondary.py-5
              %span.material-symbols{style: "font-size: 48px; display: block; margin-bottom: 8px;"} forum
              %p Send a message to test the LLM tool-calling loop.
              %p.small
                Type
                %code /clear
                to reset history.

          -# Render messages as chat bubbles. Assistant messages with tool_calls
          -# and tool-result messages are not rendered as bubbles — instead they
          -# are collected and shown as tool-round boxes before the next assistant
          -# text message. This mirrors the actual flow: call tool → get result →
          -# assistant responds.
          - pending_rounds = []
          - @messages.each do |msg|
            - if msg.role == "user"
              .d-flex.justify-content-end.mb-2
                .chat-bubble.chat-user.px-3.py-2{style: "max-width: 80%;"}
                  = simple_format(msg.content, {}, wrapper_tag: "span")
            - elsif msg.role == "assistant" && msg.tool_calls.present?
              -# Assistant requested tool calls — collect them for display.
              - msg.tool_calls.each do |tc|
                - fn = tc.is_a?(Hash) ? (tc["function"] || tc[:function]) : nil
                - if fn
                  - pending_rounds << { tool: fn["name"] || fn[:name], arguments: fn["arguments"] || fn[:arguments] }
            - elsif msg.role == "tool"
              -# Attach tool result to the most recent pending round.
              - if pending_rounds.any?
                - pending_rounds.last[:result] = msg.content
            - elsif msg.role == "assistant"
              -# Final assistant text response — show any pending tool rounds first.
              - if pending_rounds.any?
                .mb-2
                  - pending_rounds.each do |round|
                    .chat-tool-round.mx-2.mb-1.px-3.py-2.small
                      .d-flex.align-items-center.gap-1.mb-1
                        %span.material-symbols{style: "font-size: 14px;"} build
                        %strong= round[:tool]
                        %code.ms-2= round[:arguments]
                      %details
                        %summary.text-body-secondary Result
                        %pre.mt-1.mb-0= round[:result].to_s
                  - pending_rounds = []
              .d-flex.justify-content-start.mb-2
                .chat-bubble.chat-assistant.px-3.py-2{style: "max-width: 80%;"}
                  = simple_format(msg.content, {}, wrapper_tag: "span")

        %hr.my-3

        = form_with url: chat_path, method: :post, class: "d-flex gap-2" do |f|
          = f.text_field :message, class: "form-control", placeholder: "Type a message...", autofocus: true, autocomplete: "off"
          = f.submit "Send", class: "btn btn-primary"
