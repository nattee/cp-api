.row.justify-content-center
  .col-lg-8.col-xl-6
    .card
      .card-body.p-3
        .d-flex.justify-content-between.align-items-center.mb-3
          %h5.card-title.mb-0
            = resource_icon("chats")
            Chat Playground
          = link_to chat_path, data: { turbo_method: :post, turbo_frame: "_top" }, params: { message: "/clear" }, class: "btn btn-sm btn-outline-secondary" do
            %span.material-symbols{style: "font-size: 16px; vertical-align: middle;"} delete
            Clear

        .chat-messages{style: "max-height: 60vh; overflow-y: auto;", "data-controller" => "scroll-bottom"}
          - if @messages.empty? && @tool_rounds.empty?
            .text-center.text-body-secondary.py-5
              %span.material-symbols{style: "font-size: 48px; display: block; margin-bottom: 8px;"} forum
              %p Send a message to test the LLM tool-calling loop.
              %p.small
                Type
                %code /clear
                to reset history.

          - @messages.each_with_index do |msg, i|
            - if msg.role == "user"
              .d-flex.justify-content-end.mb-2
                .chat-bubble.chat-user.px-3.py-2{style: "max-width: 80%;"}
                  = simple_format(msg.content, {}, wrapper_tag: "span")
            - elsif msg.role == "assistant"
              -# Show tool rounds before the last assistant message
              - if @tool_rounds.any? && i == @messages.size - 1
                .mb-2
                  - @tool_rounds.each do |round|
                    .chat-tool-round.mx-2.mb-1.px-3.py-2.small
                      .d-flex.align-items-center.gap-1.mb-1
                        %span.material-symbols{style: "font-size: 14px;"} build
                        %strong= round[:tool]
                      .text-body-secondary
                        %div
                          Arguments:
                          %code= round[:arguments]
                        %div.mt-1
                          Result:
                          %code= round[:result].truncate(300)
              .d-flex.justify-content-start.mb-2
                .chat-bubble.chat-assistant.px-3.py-2{style: "max-width: 80%;"}
                  = simple_format(msg.content, {}, wrapper_tag: "span")

        %hr.my-3

        = form_with url: chat_path, method: :post, class: "d-flex gap-2" do |f|
          = f.text_field :message, class: "form-control", placeholder: "Type a message...", autofocus: true, autocomplete: "off"
          = f.submit "Send", class: "btn btn-primary"
