.d-flex.justify-content-between.align-items-center.mb-3
  %h1
    = @course_offering.course.course_no
    = @course_offering.course.name
    %small.text-muted= "— #{@course_offering.semester.display_name} #{Semester::SEMESTER_LABELS[@course_offering.semester.semester_number]}"
  .d-flex.gap-2
    - if current_user.admin?
      = link_to "Edit", edit_course_offering_path(@course_offering), class: "btn btn-outline-secondary"
    = link_to "Back", semester_path(@course_offering.semester), class: "btn btn-outline-primary"

.card
  .card-body
    .detail-section
      %dl.dl-fields.row.mb-0
        %dt.col-sm-3 Course
        %dd.col-sm-9
          = link_to course_path(@course_offering.course) do
            = "#{@course_offering.course.course_no} #{@course_offering.course.name}"

        %dt.col-sm-3 Semester
        %dd.col-sm-9
          = link_to semester_path(@course_offering.semester) do
            = "#{@course_offering.semester.display_name} — #{Semester::SEMESTER_LABELS[@course_offering.semester.semester_number]}"

        %dt.col-sm-3 Status
        %dd.col-sm-9
          %span.badge{class: "badge-#{@course_offering.status.dasherize}"}= @course_offering.status.titleize

        - if @course_offering.remark.present?
          %dt.col-sm-3 Remark
          %dd.col-sm-9= @course_offering.remark

    .detail-section
      %h6.section-title Sections
      - if @course_offering.sections.any?
        - @course_offering.sections.includes(teachings: :staff, time_slots: :room).order(:section_number).each do |section|
          .card.mb-2
            .card-body.py-2.px-3
              .d-flex.justify-content-between.align-items-center
                %strong Section #{section.section_number}
              - if section.remark.present?
                %p.text-muted.mb-0.mt-1.small= section.remark
              - if section.time_slots.any?
                .table-responsive.mt-2
                  %table.table.table-sm.mb-0
                    %thead
                      %tr
                        %th Day
                        %th Time
                        %th Room
                        - if section.time_slots.any? { |ts| ts.remark.present? }
                          %th Remark
                    %tbody
                      - section.time_slots.order(:day_of_week, :start_time).each do |ts|
                        %tr
                          %td= ts.day_name
                          %td= ts.time_range
                          %td
                            - if ts.room
                              = ts.room.display_name
                            - else
                              %span.text-muted TBA
                          - if section.time_slots.any? { |t| t.remark.present? }
                            %td= ts.remark
              - if section.teachings.any?
                .mt-2
                  - section.teachings.each do |teaching|
                    .d-inline-flex.align-items-center.me-3
                      %span.material-symbols.me-1{style: "font-size: 16px; opacity: 0.5"} person
                      = link_to teaching.staff.display_name_th, staff_path(teaching.staff)
                      %span.text-muted.ms-1.small= "(#{teaching.load_ratio})"
      - else
        %p.text-muted.mb-0 No sections defined.
