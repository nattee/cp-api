.row.justify-content-center
  .col-md-5.col-lg-4
    .card
      .card-body.p-4
        %h3.card-title.text-center.mb-4 Sign In
        - if flash[:alert]
          .alert.alert-danger.alert-dismissible.fade.show{role: "alert"}
            = flash[:alert]
            %button.btn-close{"data-bs-dismiss" => "alert", "aria-label" => "Close"}
        - if flash[:notice]
          .alert.alert-success.alert-dismissible.fade.show{role: "alert"}
            = flash[:notice]
            %button.btn-close{"data-bs-dismiss" => "alert", "aria-label" => "Close"}

        = form_with url: login_path, method: :post do |f|
          .mb-3
            = f.label :username, class: "form-label"
            = f.text_field :username, class: "form-control", autofocus: true, required: true
          .mb-3
            = f.label :password, class: "form-label"
            = f.password_field :password, class: "form-control", required: true
          = f.submit "Sign In", class: "btn btn-primary w-100"
