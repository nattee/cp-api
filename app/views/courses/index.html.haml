.card{"data-controller" => "datatable course-filter", "data-course-filter-token-col-value" => "6"}
  .card-body.p-3
    .d-flex.align-items-center.mb-3.gap-3.flex-wrap
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
        = resource_icon
        Courses
      = render "shared/course_filters", programs: @course_programs
      - if current_user.admin?
        = link_to "New Course", new_course_path, class: "btn btn-primary btn-sm ms-auto"
    .table-responsive
      %table.table.table-hover.mb-0{"data-datatable-target" => "table"}
        %thead
          %tr
            %th Course No
            %th Name
            %th Revision Year (B.E.)
            %th Program
            %th Credits
            %th GenEd
            %th.d-none Filter tokens
            %th Actions
        %tbody
          - @courses.each do |course|
            %tr
              %td
                = course.course_no
                - if course.auto_generated == "copied"
                  %span.badge.badge-auto-copied.ms-1 Copied
                - elsif course.auto_generated == "placeholder"
                  %span.badge.badge-auto-placeholder.ms-1 Placeholder
              %td= course.name
              %td= course.revision_year_be
              %td= course.programs.map { |p| p.short_name.presence || p.name_en }.join(", ")
              %td= course.credits
              %td
                - if course.is_gened?
                  %span.badge.badge-active GenEd
              %td.d-none= course_filter_tokens(course)
              %td
                = link_to course, class: "btn-ghost btn-ghost-primary me-1", title: "Show" do
                  %span.material-symbols{style: "font-size: 18px"} visibility
                - if current_user.admin?
                  = link_to edit_course_path(course), class: "btn-ghost btn-ghost-secondary me-1", title: "Edit" do
                    %span.material-symbols{style: "font-size: 18px"} edit
                  = link_to course, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn-ghost btn-ghost-danger", title: "Delete" do
                    %span.material-symbols{style: "font-size: 18px"} delete
