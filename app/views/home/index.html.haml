-# The home launchpad. Areas come from Navigation::AREAS, reports from
-# Reports::Catalog - never hardcode either list here.
-# Reports render as link lists, not cards: with 14 of them, card treatment
-# swamps the entity bands and makes this page a near-copy of the hub.
-#
-# Each band is the "_area_band" partial, not an inline Proc - see that
-# partial's header comment for why (a Proc-with-markup called more than once
-# duplicated earlier bands' output).
-#
-# Band order: Records, Teaching setup, Reports, Your account, Administration.
-# The design spec lists Administration before Your account; here it's the
-# reverse, deliberately - keeping Your account fourth means it sits in the
-# same position on every view, instead of jumping up eight cards when the
-# Administration band disappears for a non-admin.

.card
  .card-body.p-3
    = render "area_band", title: "Records", group: :records
    = render "area_band", title: "Teaching setup", group: :teaching_setup

    .mb-4
      %h6.text-uppercase.text-body-secondary.small.fw-semibold.mb-2
        = link_to "Reports", reports_path, class: "text-decoration-none text-reset"
      %p.small.text-body-secondary.mb-3 Read-only analyses across students, courses and teaching.
      - @report_sections.each do |section_key, entries|
        .mb-3
          %p.small.fw-semibold.mb-1= Reports::Catalog::SECTIONS[section_key]
          .d-flex.flex-wrap.column-gap-4.row-gap-1
            - entries.each do |entry|
              = link_to entry.title, catalog_report_path(entry), class: "small text-decoration-none"

    -# Profile shares this band with LINE Account but comes from outside the
    -# constant, so this band is written out rather than using the partial.
    .mb-4
      %h6.text-uppercase.text-body-secondary.small.fw-semibold.mb-2 Your account
      .row.g-3
        = render "area_card", path: user_path(current_user), icon_key: "profile",
                              label: "Profile",
                              description: "Your own account details and LINE link status."
        - Navigation.visible_to(Navigation.for_group(:account), user: current_user).each do |area|
          = render "area_card", path: navigation_area_path(area), icon_key: area[:key],
                                label: area[:label], description: area[:description]

    = render "area_band", title: "Administration", group: :admin
