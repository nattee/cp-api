.card{"data-controller" => "datatable"}
  .card-body.p-3
    .d-flex.justify-content-between.align-items-center.mb-3
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
        = resource_icon
        API Events
      - if @error_count_24h > 0
        %span.badge.bg-danger
          = "#{@error_count_24h} #{"error".pluralize(@error_count_24h)} in 24h"

    .d-flex.gap-2.mb-3
      = link_to "All", api_events_path, class: "btn btn-sm #{params[:source].blank? && params[:severity].blank? ? 'btn-secondary' : 'btn-outline-secondary'}"
      - ApiEvent::SOURCES.each do |source|
        = link_to source.titleize, api_events_path(source: source, severity: params[:severity]), class: "btn btn-sm #{params[:source] == source ? 'btn-secondary' : 'btn-outline-secondary'}"

    .table-responsive
      %table.table.table-hover.mb-0{"data-datatable-target" => "table"}
        %thead
          %tr
            %th Time
            %th Source
            %th Severity
            %th Message
            %th Details
        %tbody
          - @api_events.each do |event|
            %tr
              %td.text-nowrap= event.created_at.strftime("%m-%d %H:%M:%S")
              %td
                %code= event.source
              %td
                %span.badge{class: event.severity == "error" ? "bg-danger" : "bg-warning"}
                  = event.severity
              %td= truncate(event.message, length: 80)
              %td
                - if event.details.present?
                  %details
                    %summary.text-body-secondary Details
                    %pre.mt-1.mb-0.small= JSON.pretty_generate(event.details)
