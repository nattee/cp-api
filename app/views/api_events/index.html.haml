.card{"data-controller" => "datatable", "data-datatable-order-value" => "0:desc"}
  .card-body.p-3
    .d-flex.justify-content-between.align-items-center.mb-3
      %h5.card-title.mb-0.fw-semibold.d-flex.align-items-center
        = resource_icon
        API Events
      - if @error_count_24h > 0
        %span.badge.bg-danger
          = "#{@error_count_24h} #{"error".pluralize(@error_count_24h)} in 24h"

    .d-flex.gap-2.mb-3
      = link_to "All", api_events_path, class: "btn btn-sm #{params[:service].blank? && params[:severity].blank? ? 'btn-secondary' : 'btn-outline-secondary'}"
      - ApiEvent::SERVICES.each do |service|
        = link_to service.titleize, api_events_path(service: service, severity: params[:severity]), class: "btn btn-sm #{params[:service] == service ? 'btn-secondary' : 'btn-outline-secondary'}"
      .vr
      = link_to "Errors", api_events_path(service: params[:service], severity: "error"), class: "btn btn-sm #{params[:severity] == 'error' ? 'btn-danger' : 'btn-outline-danger'}"

    .table-responsive
      -# Column 0 (Time) uses DataTables orthogonal data: the td has a
      -# data-order attribute with millisecond precision for correct sorting,
      -# while the visible text shows only HH:MM:SS for readability.
      %table.table.table-hover.mb-0{"data-datatable-target" => "table"}
        %thead
          %tr
            %th Time
            %th Service
            %th Action
            %th Severity
            %th Response
            %th Details
        %tbody
          - @api_events.each do |event|
            %tr
              -# Orthogonal data: data-order has millisecond-precision timestamp for
              -# correct sorting; the visible text omits milliseconds for readability.
              %td.text-nowrap{"data-order" => event.created_at.strftime("%Y-%m-%d %H:%M:%S.%L")}
                = event.created_at.strftime("%m-%d %H:%M:%S")
              %td
                %code= event.service
              %td
                - action_label = event.action
                - if event.action == "tool_call" && event.details&.dig("tool")
                  - action_label = "tool: #{event.details["tool"]}"
                - if event.severity == "error" || event.severity == "warning"
                  - action_label += " — #{event.message}" unless event.message == "OK"
                %code= action_label
              %td
                - badge_class = case event.severity
                - when "error" then "bg-danger"
                - when "warning" then "bg-warning"
                - else "bg-secondary"
                %span.badge{class: badge_class}= event.severity
              %td.text-nowrap
                - if event.response_time_ms
                  = "#{event.response_time_ms} ms"
              %td
                - if event.details.present?
                  %details
                    %summary.text-body-secondary Details
                    = render_api_event_details(event.details)
