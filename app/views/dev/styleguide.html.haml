      // Custom badges
      css += ".badge-admin { background-color: " + rgba(c.danger, 0.2) + " !important; color: " + lighten(c.danger, 12) + " !important; border-color: " + rgba(c.danger, 0.4) + " !important; }\n";
      css += ".badge-editor { background-color: " + rgba(c.primary, 0.2) + " !important; color: " + lighten(saturate(c.primary, 30), 10) + " !important; border-color: " + rgba(c.primary, 0.4) + " !important; }\n";
