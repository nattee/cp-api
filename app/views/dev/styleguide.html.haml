      css += ".btn-ghost-primary:hover { background-color: " + rgba(c.primary, 0.15) + " !important; }\n";
      css += ".btn-ghost-secondary { color: " + c.secondary + " !important; }\n";
      css += ".btn-ghost-secondary:hover { background-color: " + rgba(c.secondary, 0.15) + " !important; color: " + lighten(c.secondary, 20) + " !important; }\n";
      css += ".btn-ghost-danger { color: " + c.danger + " !important; }\n";
      css += ".btn-ghost-danger:hover { background-color: " + rgba(c.danger, 0.15) + " !important; }\n";

      // Table
      css += ".table { color: " + font + " !important; }\n";

      // --- Flatpickr overrides (mirrors application.scss .flatpickr-calendar block) ---
      var lib = computeLibraryColors();
      var fpCal = ".flatpickr-calendar";
      css += fpCal + " { background: " + s["card-bg"] + " !important; border-color: " + lib["flatpickr-border-color"].css + " !important; }\n";
      css += fpCal + " .flatpickr-months .flatpickr-month { color: " + lib["flatpickr-header-color"].css + " !important; }\n";
      css += fpCal + " .flatpickr-months .flatpickr-prev-month, " + fpCal + " .flatpickr-months .flatpickr-next-month { color: " + lib["flatpickr-header-color"].css + " !important; }\n";
      css += fpCal + " .flatpickr-months .flatpickr-prev-month:hover, " + fpCal + " .flatpickr-months .flatpickr-next-month:hover { color: " + c.primary + " !important; }\n";
      css += fpCal + " .flatpickr-current-month { color: " + lib["flatpickr-header-color"].css + " !important; }\n";
      css += fpCal + " .flatpickr-current-month .flatpickr-monthDropdown-months { background: " + s["card-bg"] + " !important; color: " + lib["flatpickr-header-color"].css + " !important; }\n";
      css += fpCal + " .flatpickr-current-month input.cur-year { color: " + lib["flatpickr-header-color"].css + " !important; }\n";
      css += fpCal + " .flatpickr-current-month .numInputWrapper span.arrowUp:after { border-bottom-color: " + lib["flatpickr-spinner-color"].css + " !important; }\n";
      css += fpCal + " .flatpickr-current-month .numInputWrapper span.arrowDown:after { border-top-color: " + lib["flatpickr-spinner-color"].css + " !important; }\n";
      css += fpCal + " span.flatpickr-weekday { color: " + lib["flatpickr-weekday-color"].css + " !important; }\n";
      css += fpCal + " .flatpickr-day { color: " + lib["flatpickr-day-color"].css + " !important; }\n";
      css += fpCal + " .flatpickr-day:hover { background: " + lib["flatpickr-day-hover-bg"].css + " !important; border-color: " + lib["flatpickr-day-hover-bg"].css + " !important; }\n";
      css += fpCal + " .flatpickr-day.selected { background: " + lib["flatpickr-selected-bg"].css + " !important; border-color: " + lib["flatpickr-selected-bg"].css + " !important; color: " + lib["flatpickr-selected-color"].css + " !important; }\n";
      css += fpCal + " .flatpickr-day.today { border-color: " + lib["flatpickr-selected-bg"].css + " !important; }\n";
      css += fpCal + " .flatpickr-day.prevMonthDay, " + fpCal + " .flatpickr-day.nextMonthDay { color: " + lib["flatpickr-muted-color"].css + " !important; }\n";

      // --- Select2 overrides (mirrors application.scss Select2 section) ---
      css += ".select2-container--bootstrap-5 .select2-dropdown { background-color: " + lighten(c.dark, 10) + " !important; border-color: rgba(255, 255, 255, 0.15) !important; color: " + lib["s2-text-color"].css + " !important; }\n";
      css += ".select2-container--bootstrap-5 .select2-selection { background-color: " + s["input-bg"] + " !important; color: " + lib["s2-text-color"].css + " !important; border-color: rgba(255, 255, 255, 0.15) !important; }\n";
      css += ".select2-container--bootstrap-5 .select2-selection--single .select2-selection__rendered { color: " + lib["s2-text-color"].css + " !important; }\n";
      css += ".select2-container--bootstrap-5.select2-container--focus .select2-selection, .select2-container--bootstrap-5.select2-container--open .select2-selection { border-color: " + lib["s2-focus-border"].css + " !important; box-shadow: 0 0 0 0.25rem " + rgba(c.primary, 0.25) + " !important; }\n";
      css += ".select2-container--bootstrap-5 .select2-results__option { color: " + lib["s2-text-color"].css + " !important; }\n";
      css += ".select2-container--bootstrap-5 .select2-dropdown .select2-results__options .select2-results__option.select2-results__option--highlighted { background-color: " + rgba(c.primary, 0.25) + " !important; color: " + lib["s2-text-color"].css + " !important; }\n";
      css += ".select2-container--bootstrap-5 .select2-dropdown .select2-results__options .select2-results__option.select2-results__option--selected, .select2-container--bootstrap-5 .select2-dropdown .select2-results__options .select2-results__option[aria-selected=true]:not(.select2-results__option--highlighted) { background-color: " + c.primary + " !important; color: " + c.dark + " !important; }\n";
      css += ".select2-container--bootstrap-5 .select2-dropdown .select2-search .select2-search__field { background-color: " + s["input-bg"] + " !important; color: " + lib["s2-text-color"].css + " !important; }\n";
      css += ".select2-container--bootstrap-5 .select2-dropdown .select2-search .select2-search__field:focus { border-color: " + lib["s2-focus-border"].css + " !important; box-shadow: 0 0 0 0.25rem " + rgba(c.primary, 0.25) + " !important; }\n";

      // --- DataTables overrides ---
      css += ":root { --dt-row-selected: " + hexToRgbStr(c.primary) + "; }\n";

      styleEl.textContent = css;

      // --- Update 3rd-party library color swatches ---
      document.querySelectorAll(".library-swatch").forEach(function(el) {
        var entry = lib[el.dataset.libKey];
        if (entry) el.style.backgroundColor = entry.css;
      });
      document.querySelectorAll(".lib-hex").forEach(function(el) {
        var entry = lib[el.dataset.libKey];
        if (entry) el.textContent = entry.hex;
      });

      // Update CSS custom properties
      Object.keys(colors).forEach(function(key) {
        root.style.setProperty("--sass-" + key, colors[key]);
      });
      Object.keys(surfaces).forEach(function(key) {
        root.style.setProperty("--sass-" + key, surfaces[key]);
      });

      // Update color picker values and hex inputs
      document.querySelectorAll(".color-picker").forEach(function(el) {
        el.value = colors[el.dataset.colorKey];
      });
      document.querySelectorAll(".hex-input").forEach(function(el) {
        if (document.activeElement !== el) el.value = colors[el.dataset.colorKey];
      });
      document.querySelectorAll(".surface-picker").forEach(function(el) {
        el.value = surfaces[el.dataset.surfaceKey];
      });
      document.querySelectorAll(".hex-input-surface").forEach(function(el) {
        if (document.activeElement !== el) el.value = surfaces[el.dataset.surfaceKey];
      });
    }

    // --- Initialize pickers ---
    applyColors();

    // Keys that trigger re-derivation of dependent colors
    // primary is included because flatpickr-selected-bg and ts-focus-border depend on it
    var deriveTriggers = ["dark", "light", "body-color", "primary"];

    // Base color pickers
    document.querySelectorAll(".color-picker").forEach(function(el) {
      el.addEventListener("input", function() {
        colors[el.dataset.colorKey] = el.value;
        if (deriveTriggers.indexOf(el.dataset.colorKey) !== -1) deriveSurfaces();
        applyColors();
      });
    });

    // Base color hex text inputs
    document.querySelectorAll(".hex-input").forEach(function(el) {
      el.addEventListener("input", function() {
        var val = el.value.trim();
        if (/^#[0-9a-fA-F]{6}$/.test(val)) {
          colors[el.dataset.colorKey] = val.toLowerCase();
          if (deriveTriggers.indexOf(el.dataset.colorKey) !== -1) deriveSurfaces();
          applyColors();
        }
      });
    });

    // Surface color pickers (manual override)
    document.querySelectorAll(".surface-picker").forEach(function(el) {
      el.addEventListener("input", function() {
        var key = el.dataset.surfaceKey;
        var lock = document.querySelector('.surface-lock[data-surface-key="' + key + '"]');
        if (lock) lock.checked = true;
        surfaces[key] = el.value;
        applyColors();
      });
    });

    // Surface color hex text inputs
    document.querySelectorAll(".hex-input-surface").forEach(function(el) {
      el.addEventListener("input", function() {
        var val = el.value.trim();
        if (/^#[0-9a-fA-F]{6}$/.test(val)) {
          var key = el.dataset.surfaceKey;
          var lock = document.querySelector('.surface-lock[data-surface-key="' + key + '"]');
          if (lock) lock.checked = true;
          surfaces[key] = val.toLowerCase();
          applyColors();
        }
      });
    });

    // When unchecking override, re-derive from $dark
    document.querySelectorAll(".surface-lock").forEach(function(el) {
      el.addEventListener("change", function() {
        if (!el.checked) {
          deriveSurfaces();
          applyColors();
        }
      });
    });

    // Reset button
    document.getElementById("reset-colors").addEventListener("click", function() {
      Object.assign(colors, originalColors);
      Object.assign(surfaces, originalSurfaces);
      document.querySelectorAll(".surface-lock").forEach(function(el) { el.checked = false; });
      applyColors();
    });

    // Copy SCSS button
    document.getElementById("copy-scss").addEventListener("click", function() {
      var lines = [];
      var nameMap = {"body-color": "$body-color-dark", light: "$light", dark: "$dark", primary: "$primary", secondary: "$secondary", info: "$info", success: "$success", warning: "$warning", danger: "$danger"};
      Object.keys(nameMap).forEach(function(key) {
        var pad = "            ".slice(nameMap[key].length);
        lines.push(nameMap[key] + ":" + pad + colors[key] + ";");
      });

      // Add overridden surfaces
      var surfaceNames = {"body-bg": "$body-bg", "card-bg": "$card-bg", "input-bg": "$input-bg", "input-group-addon-bg": "$input-group-addon-bg", "input-icon-color": "$input-icon-color"};
      var hasOverrides = false;
      Object.keys(surfaceNames).forEach(function(key) {
        var lock = document.querySelector('.surface-lock[data-surface-key="' + key + '"]');
        if (lock && lock.checked) {
          if (!hasOverrides) { lines.push(""); hasOverrides = true; }
          lines.push(surfaceNames[key] + ": " + surfaces[key] + ";");
        }
      });

      navigator.clipboard.writeText(lines.join("\n")).then(function() {
        var btn = document.getElementById("copy-scss");
        var orig = btn.innerHTML;
        btn.innerHTML = '<span class="material-symbols" style="font-size: 16px; vertical-align: -3px">check</span> Copied!';
        setTimeout(function() { btn.innerHTML = orig; }, 2000);
      });
    });
  });
